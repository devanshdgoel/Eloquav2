# Copy this file to .env and fill in the real values.
# .env is gitignored and must never be committed.

# Firebase project config
# Obtain these from: Firebase Console -> Project Settings -> Your apps -> Web app
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=

# Backend base URL (leave blank in development; env.js auto-detects the local IP)
API_BASE_URL=

# Google OAuth client IDs (required only when enabling Google Sign-In)
# Obtain these from: Google Cloud Console -> APIs & Services -> Credentials
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=
